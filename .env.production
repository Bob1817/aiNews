# ============================================
# AI News Tool - 生产环境配置
# ============================================

# 🎯 应用配置
NODE_ENV=production
PORT=8080
HOST=0.0.0.0

# 🗄️ 数据库配置
# DATABASE_URL=postgresql://user:password@production-db:5432/ainews_prod
DB_MAX_CONNECTIONS=20
DB_TIMEOUT=15000

# 🔗 API 配置
API_BASE_URL=https://your-api-domain.com
API_TIMEOUT=30000
RATE_LIMIT_WINDOW_MS=900000  # 15分钟
RATE_LIMIT_MAX=100

# 🔒 安全配置
# 请在生产环境修改为强密码！
JWT_SECRET=change-this-to-a-strong-random-secret-key-min-32-chars
JWT_EXPIRES_IN=7d
CORS_ORIGINS=https://your-domain.com,https://app.your-domain.com
RATE_LIMIT_ENABLED=true

# 📝 日志配置
LOG_LEVEL=warn
LOG_FORMAT=json
ENABLE_FILE_LOGGING=true
LOG_FILE_PATH=./logs/app.log

# 📰 新闻 API 配置
NEWS_API_DEFAULT_KEYWORDS=technology,business,science,health
NEWS_API_DEFAULT_INDUSTRIES=科技,商业,科学,医疗
NEWS_API_TIMEOUT=12000
NEWS_API_MAX_RETRIES=3

# 🤖 AI 服务配置
AI_DEFAULT_MODEL=gpt-3.5-turbo
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.7
AI_TIMEOUT=30000

# 🌐 前端配置 (Vite 环境变量)
VITE_API_BASE_URL=https://your-api-domain.com

# ============================================
# 第三方服务配置 (按需设置)
# ============================================

# 📰 NewsAPI.org (https://newsapi.org)
# NEWSAPI_API_KEY=your_newsapi_key_here

# 📰 The Guardian (https://open-platform.theguardian.com)
# GUARDIAN_API_KEY=your_guardian_key_here

# 📰 New York Times (https://developer.nytimes.com)
# NYT_API_KEY=your_nyt_key_here

# 🤖 OpenAI (https://platform.openai.com)
# OPENAI_API_KEY=your_openai_key_here

# 🤖 Anthropic (https://console.anthropic.com)
# ANTHROPIC_API_KEY=your_anthropic_key_here

# 🤖 Google AI (https://makersuite.google.com)
# GOOGLE_AI_API_KEY=your_google_ai_key_here

# ☁️ Supabase (https://supabase.com)
# SUPABASE_URL=your_supabase_url
# SUPABASE_ANON_KEY=your_supabase_anon_key
