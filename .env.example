# ============================================
# AI News Tool - 环境变量配置
# ============================================

# 🎯 应用配置
NODE_ENV=development
PORT=3001
HOST=localhost

# 🗄️ 数据库配置
DATABASE_URL=postgresql://localhost:5432/ainews
DB_MAX_CONNECTIONS=10
DB_TIMEOUT=10000

# 🔗 API 配置
API_BASE_URL=http://localhost:3001
API_TIMEOUT=30000
RATE_LIMIT_WINDOW_MS=900000  # 15分钟
RATE_LIMIT_MAX=100

# 🔒 安全配置
JWT_SECRET=your-secret-key-change-in-production-1234567890
JWT_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT_ENABLED=true

# 📝 日志配置
LOG_LEVEL=info
LOG_FORMAT=text
ENABLE_FILE_LOGGING=false
LOG_FILE_PATH=./logs/app.log

# 📰 新闻 API 配置
NEWS_API_DEFAULT_KEYWORDS=technology,business,science,health
NEWS_API_DEFAULT_INDUSTRIES=科技,商业,科学,医疗
NEWS_API_TIMEOUT=12000
NEWS_API_MAX_RETRIES=3

# 🤖 AI 服务配置
AI_DEFAULT_MODEL=gpt-3.5-turbo
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.7
AI_TIMEOUT=30000

# 🌐 前端配置 (Vite 环境变量)
VITE_API_BASE_URL=http://localhost:3001

# ============================================
# 第三方服务配置 (按需设置)
# ============================================

# 📰 NewsAPI.org (https://newsapi.org)
NEWSAPI_API_KEY=70803be67f5d4647b6e54a35f0615d25

# 📰 The Guardian (https://open-platform.theguardian.com)
# GUARDIAN_API_KEY=your_guardian_key_here

# 📰 New York Times (https://developer.nytimes.com)
# NYT_API_KEY=your_nyt_key_here

# 🤖 OpenAI (https://platform.openai.com)
# OPENAI_API_KEY=your_openai_key_here

# 🤖 Anthropic (https://console.anthropic.com)
# ANTHROPIC_API_KEY=your_anthropic_key_here

# 🤖 Google AI (https://makersuite.google.com)
# GOOGLE_AI_API_KEY=your_google_ai_key_here

# ☁️ Supabase (https://supabase.com)
# SUPABASE_URL=your_supabase_url
# SUPABASE_ANON_KEY=your_supabase_anon_key

# ============================================
# 生产环境配置示例
# ============================================
# NODE_ENV=production
# PORT=8080
# HOST=0.0.0.0
# DATABASE_URL=postgresql://user:password@production-db:5432/ainews_prod
# JWT_SECRET=strong-production-secret-with-at-least-32-characters
# CORS_ORIGINS=https://your-domain.com,https://app.your-domain.com
# LOG_LEVEL=warn
# LOG_FORMAT=json
# ENABLE_FILE_LOGGING=true